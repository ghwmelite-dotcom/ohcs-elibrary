# Cloudflare Pages Headers
# https://developers.cloudflare.com/pages/platform/headers

# Cache static assets for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache icons and images
/icons/*
  Cache-Control: public, max-age=31536000, immutable

/splash/*
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=604800

# Service worker - no cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest - cache for 1 day
/manifest.json
  Cache-Control: public, max-age=86400

# HTML - no cache to ensure fresh content
/*.html
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# Security headers for all pages
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(self), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://js.paystack.co https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' https: data: blob:; connect-src 'self' https://ohcs-elibrary-api.ghwmelite.workers.dev https://api.paystack.co https://tenor.googleapis.com https://accounts.google.com https://oauth2.googleapis.com https://fonts.googleapis.com https://static.cloudflareinsights.com https://cloudflareinsights.com; frame-src 'self' https://challenges.cloudflare.com https://js.paystack.co https://ohcs-elibrary-api.ghwmelite.workers.dev https://drive.google.com https://docs.google.com; object-src 'self' https://ohcs-elibrary-api.ghwmelite.workers.dev blob:; media-src 'self' blob:; worker-src 'self' blob:;
